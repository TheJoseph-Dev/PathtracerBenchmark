struct IsecInfo {
    float tmin;
    float tmax;
};

IsecInfo RayAABBIsec(Ray ray, vec3 bbMin, vec3 bbMax, vec3 invDir) {
    IsecInfo info;
    vec3 t0s = (bbMin - ray.origin) * invDir;
    vec3 t1s = (bbMax - ray.origin) * invDir;
    vec3 tsmaller = min(t0s, t1s);
    vec3 tbigger  = max(t0s, t1s);
    float tmin = max(max(tsmaller.x, tsmaller.y), max(tsmaller.z, 0.0));
    float tmax = min(min(tbigger.x, tbigger.y), tbigger.z);
    info.tmin = tmin;
    info.tmax = tmax;
    return info;
}

/* Optimizations
    - Reduce the amount of RayAABBIsec
    - Wide BVHs (BVH4 / BVH8)
    - SOA layout instead of structs
    - Pre-sorted triangles in leaves
    - Quantized bounds
*/
void TraversalBVH(Ray ray, inout Hit hit) {
    //if(USE_STATS) atomicAdd(statistics.rays, 1ul);
    statsRays++;
    vec3 invDir = 1.0 / ray.dir;
    int stack[MAX_TRAVERSAL_DEPTH];
    int stkptr = 0;
    stack[stkptr++] = 0;

    while (stkptr > 0 && stkptr + 2 < MAX_TRAVERSAL_DEPTH) {
        //if(USE_STATS) atomicAdd(statistics.traversals, 1ul);
        statsTraversals++;
        int nodeIdx = stack[--stkptr];
        BVHNode n = bvhNodes[nodeIdx];

        // Test current node
        /*
        IsecInfo isec = RayAABBIsec(ray, n, invDir);
        if (isec.tmax < isec.tmin || isec.tmin > hit.t)
            continue;
        */

        bool isLeaf = (n.left == -1);

        if (isLeaf) {
            for (uint i = 0; i < n.triCount; ++i) {
                //if(USE_STATS) atomicAdd(statistics.isecs, 1ul);
                statsIsecs++;
                Triangle tri = triangles[n.triIdx + i];

                vec3 v0 = vertices[tri.indices.x].position.xyz;
                vec3 v1 = vertices[tri.indices.y].position.xyz;
                vec3 v2 = vertices[tri.indices.z].position.xyz;

                vec3 isec = triIntersect(ray.origin, ray.dir, v0, v1, v2);
                if (miss(isec.x)) continue;

                if (isec.x > hit.t) continue;
                hit.t = isec.x;
                hit.u = isec.y;
                hit.v = isec.z;
                hit.triIdx = n.triIdx + i;
            }
        } else {
            int left = n.left;
            int right = n.right;

            bool hitL = false, hitR = false;
            IsecInfo lIsec, rIsec;

            if (left >= 0) {
                lIsec = RayAABBIsec(ray, bvhNodes[left].bboxMin.xyz, bvhNodes[left].bboxMax.xyz, invDir);
                hitL = !(lIsec.tmax < lIsec.tmin || lIsec.tmin > hit.t);
            }

            if (right >= 0) {
                rIsec = RayAABBIsec(ray, bvhNodes[right].bboxMin.xyz, bvhNodes[right].bboxMax.xyz, invDir);
                hitR = !(rIsec.tmax < rIsec.tmin || rIsec.tmin > hit.t);
            }

            if (hitL && hitR) {
                // push far first, near last
                if (lIsec.tmin < rIsec.tmin) {
                    stack[stkptr++] = right;
                    stack[stkptr++] = left;
                } else {
                    stack[stkptr++] = left;
                    stack[stkptr++] = right;
                }
            } 
            else if (hitL) stack[stkptr++] = left;
            else if (hitR) stack[stkptr++] = right;
        }
    }
}

struct SpaceContext {
    uint node;
    float tmin;
    float tmax;
};

void TraversalKdTree(Ray ray, inout Hit hit) {
    //if(USE_STATS) atomicAdd(statistics.rays, 1ul);
    statsRays++;
    vec3 invDir = 1.0 / ray.dir;
    SpaceContext stack[MAX_TRAVERSAL_DEPTH];
    int stkptr = 0;
    stack[stkptr++] = SpaceContext(0, -INF, INF);

    while (stkptr > 0 && stkptr + 2 < MAX_TRAVERSAL_DEPTH) {
        //if(USE_STATS) atomicAdd(statistics.traversals, 1ul);
        statsTraversals++;
        SpaceContext sc = stack[--stkptr];
        KdNode n = kdNodes[sc.node];

        if (sc.tmin >= hit.t || sc.tmin > sc.tmax) continue;

        bool isLeaf = (n.left == -1);
        if (isLeaf) {
            for (uint i = 0; i < n.triCount; ++i) {
                //if(USE_STATS) atomicAdd(statistics.isecs, 1ul);
                statsIsecs++;
                Triangle tri = triangles[kdtreeIndices[n.triIdx + i]];

                vec3 v0 = vertices[tri.indices.x].position.xyz;
                vec3 v1 = vertices[tri.indices.y].position.xyz;
                vec3 v2 = vertices[tri.indices.z].position.xyz;

                vec3 isec = triIntersect(ray.origin, ray.dir, v0, v1, v2);
                if (miss(isec.x)) continue;

                if (isec.x > hit.t) continue;
                hit.t = isec.x;
                hit.u = isec.y;
                hit.v = isec.z;
                hit.triIdx = kdtreeIndices[n.triIdx + i];
            }
        } else {
            float tsplit = (n.splitPos - ray.origin[n.axis]) * invDir[n.axis];
            bool below = ray.origin[n.axis] < n.splitPos || (ray.origin[n.axis] == n.splitPos && ray.dir[n.axis] <= 0.0);
            uint near = below ? n.left  : n.right;
            uint far  = below ? n.right : n.left;
            if (tsplit >= sc.tmax || tsplit <= 0) stack[stkptr++] = SpaceContext(near, sc.tmin, sc.tmax);
            else if (tsplit <= sc.tmin) stack[stkptr++] = SpaceContext(far, sc.tmin, sc.tmax);
            else {
                stack[stkptr++] = SpaceContext(far,  tsplit, sc.tmax);
                stack[stkptr++] = SpaceContext(near, sc.tmin, tsplit);
            }
            
        }

    }
}

/*
    ray.origin = (-0.2, 0.1, -0.6)
    ray.dir = (-, +, +)

    Node 0 (axis = 2) (-INF, INF) => tsplit0 = (0.77 - -0.6) / + = +, below = (-0.6 < 0.77) = true => near(left, -INF, tsplit0), far(right, tsplit0, INF)
    Node 1 (axis = 0) (-INF, tsplit0) => tsplit1 = (0.0 - -0.2) / - = -, below = (-0.2 < 0.0) = true => near(left, -INF, tsplit0)
    Node 2 (axis = 1) (-INF, tsplit0) => tsplit2 = (0.0 - 0.1) / + = -, below = (0.1 < 0.0) = false => near(right, -INF, tsplit2) far(left, tsplit2, tsplit0)

    near(left, -INF, tsplit0)
    near(left, -INF, tsplit0)
    far(left, tsplit2, tsplit0)
*/

void TraversalBruteForce(Ray ray, inout Hit hit) {
    for (uint tIdx = 0; tIdx < triangles.length(); ++tIdx) {
        Triangle tri = triangles[tIdx];
        vec3 v0 = vertices[tri.indices.x].position.xyz;
        vec3 v1 = vertices[tri.indices.y].position.xyz;
        vec3 v2 = vertices[tri.indices.z].position.xyz;
        vec3 isec = triIntersect(ray.origin, ray.dir, v0, v1, v2);
        
        if (miss(isec.x)) continue;
        if (isec.x >= hit.t) continue;
        hit.t = isec.x;
        hit.u = isec.y;
        hit.v = isec.z;
        hit.triIdx = tIdx;
    }
}

void EmissiveTraversalBF(Ray ray, inout Hit hit) {
    for (uint tIdx = 0; tIdx < eTriangles.length(); ++tIdx) {
        Triangle tri = eTriangles[tIdx];
        vec3 v0 = vertices[tri.indices.x].position.xyz;
        vec3 v1 = vertices[tri.indices.y].position.xyz;
        vec3 v2 = vertices[tri.indices.z].position.xyz;
        vec3 isec = triIntersect(ray.origin, ray.dir, v0, v1, v2);
        if (miss(isec.x)) continue;
        if (isec.x < hit.t) {
            hit.t = isec.x;
            hit.u = isec.y;
            hit.v = isec.z;
            hit.triIdx = tIdx | (1<<30);
        }
    }
}

Hit world(Ray ray) {
    Hit hit;
    hit.t = MAX_DIST;
    //hit.d2 = MAX_DIST;

    if(USE_BVH) TraversalBVH(ray, hit);
    else TraversalKdTree(ray, hit);

    EmissiveTraversalBF(ray, hit);

    return hit;
}

