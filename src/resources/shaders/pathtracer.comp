// Next Event Estimation
// PDF: p = p(triangle) x p(point|triangle)
// �Pick a point on a light, check visibility, and add its contribution now instead of hoping to hit it randomly later.�
// Mathematically: Lnee = \frac{Le \cdot f(\omega_i, \omega_o) \cdot \cos \theta_s \cos theta_l}{p(light)}

struct LightSample {
    vec3 wi;      // direction to light
    vec3 Le;      // emitted radiance
    float pdf;    // solid-angle PDF
};

float computeLightPdf(vec3 curPos, vec3 prevPos, uint triIdx) {
    uvec4 triIndices = emissiveIndices[triIdx];

    vec3 v0 = vertexPositions[triIndices.x].xyz;
    vec3 v1 = vertexPositions[triIndices.y].xyz;
    vec3 v2 = vertexPositions[triIndices.z].xyz;

    vec3 lightNormal = normalize(cross(v1 - v0, v2 - v0));

    float area = emissiveAreas[triIdx].x;

    vec3 toLight = curPos - prevPos;
    float dist2 = dot(toLight, toLight);
    if (dist2 < 1e-9) return 0.0;
    vec3 wi = normalize(toLight);

    float cosL = max(dot(lightNormal, -wi), 0.0); // abs(dot(lightNormal, -wi)); => double sided
    if (cosL <= 0.0) return 0.0;

    float denom = max(area * cosL * float(emissiveIndices.length()), 1e-6);
    return dist2 / denom;
}

LightSample sampleNEE(vec3 hitPos, vec3 N) {
    LightSample ls;
    ls.pdf = -1e-5;
    ls.Le  = vec3(0.0);
    ls.wi  = vec3(0.0);

    uint lightCount = emissiveIndices.length();
    if (lightCount == 0) return ls;
    
    // Uniform triangle sampling
    uint lidx = min(uint(RandomFloat01(seed) * float(lightCount)), lightCount - 1u);
    uvec4 triIndices = emissiveIndices[lidx];

    vec3 v0 = vertexPositions[triIndices.x].xyz;
    vec3 v1 = vertexPositions[triIndices.y].xyz;
    vec3 v2 = vertexPositions[triIndices.z].xyz;

    float u = RandomFloat01(seed);
    float v = RandomFloat01(seed);
    if (u + v > 1.0) { u = 1.0 - u; v = 1.0 - v; }
    vec3 lightPos = v0 + u * (v1 - v0) + v * (v2 - v0);

    vec3 lightNormal = normalize(cross(v1 - v0, v2 - v0));

    vec3 toLight = lightPos - hitPos;
    float dist2 = max(dot(toLight, toLight), 1e-5);
    float dist = sqrt(dist2);
    vec3 wi = toLight / max(1e-5, dist);

    float cosS = dot(N, wi);
    float cosL = dot(lightNormal, -wi);
    if (cosS <= 0.0 || cosL <= 0.0) return ls;

    // Shadow ray
    Ray shadow;
    shadow.origin = hitPos + N * NORMAL_OFFSET;
    shadow.dir = wi;

    if (USE_STATS) statsShadowRays++;
    Hit sh = world(shadow);
    if (sh.t < dist - 2.0*NORMAL_OFFSET) return ls;

    ls.wi = wi;
    ls.pdf = computeLightPdf(lightPos, hitPos, lidx);

    Material lm = mats[triIndices.w];
    ls.Le = lm.emissiveColor * lm.emissivePower;

    return ls;
}


vec3 diffuseSample(in vec3 normals) {
    vec3 t, b;
    buildTBN(normals, t, b);
    vec2 u = vec2(RandomFloat01(seed), RandomFloat01(seed));
    vec3 localDir = CosineSampleHemisphere(u);
    return normalize(localDir.x * t + localDir.y * b + localDir.z * normals); // raydir
}

float smithG1GGX(float NdotX, float a) {
    float a2 = a * a;
    float denom = NdotX + sqrt(max(1e-5, a2 + (1.0 - a2) * NdotX * NdotX));
    return (2.0 * NdotX) / max(1e-5, denom);
}

float smithGGX(float NdotV, float NdotL, float a) {
    return smithG1GGX(NdotV, a) * smithG1GGX(NdotL, a);
}

vec3 ggxBRDF(vec3 N, vec3 V, vec3 L, float roughness, vec3 albedo) {
    float NdotL = max(dot(N, L), 1e-6);
    float NdotV = max(dot(N, V), 1e-6);
    if (NdotL < 1e-5 || NdotV < 1e-5) return vec3(0.0);

    vec3 H = V + L;
    if (dot(H, H) < 1e-8) return vec3(0.0);
    H = normalize(H);
    float NdotH = max(dot(N, H), 1e-6);
    float VdotH = max(dot(V, H), 1e-6);

    float a = roughness * roughness;

    float a2 = a * a;
    float D = a2 / max(1e-6, (PI * pow(NdotH * NdotH * (a2 - 1.0) + 1.0, 2.0)));

    float G = smithGGX(NdotV, NdotL, a);

    vec3 F = fresnelSchlick(VdotH, albedo); // F0 = mix(vec3(0.04), albedo, mat.metallic); but my material doesn't support metalicness yet

    return (F * D * G) / max(1e-5, (4.0 * NdotL * NdotV));
}

float ggxPdf(vec3 N, vec3 V, vec3 L, float roughness) {
    vec3 H = V + L;
    if (dot(H, H) < 1e-9) return 0.0;
    H = normalize(H);
    float NdotH = max(dot(N, H), 1e-6);
    float VdotH = max(dot(V, H), 1e-6);

    if (NdotH <= 1e-5 || VdotH <= 1e-5) return 0.0;

    float a = roughness * roughness;
    float D = (a * a) / max(1e-5, (PI * pow(NdotH * NdotH * (a * a - 1.0) + 1.0, 2.0)));

    return D * NdotH / max(1e-5, (4.0 * VdotH));
}

vec3 sampleGGX(vec3 N, vec3 V, float roughness, out float pdf) {
    roughness = max(roughness, 0.03);
    float a = roughness * roughness;
    float u1 = RandomFloat01(seed);
    float u2 = RandomFloat01(seed);

    float phi = 2.0 * PI * u1;
    float cosTheta = sqrt(max(1e-6, (1.0 - u2) / (1.0 + (a*a - 1.0) * u2)));
    float sinTheta = sqrt(max(1e-6, 1.0 - cosTheta * cosTheta));

    vec3 H_local = vec3(cos(phi)*sinTheta, sin(phi)*sinTheta, cosTheta);

    vec3 T, B;
    buildTBN(N, T, B);
    vec3 bH = H_local.x*T + H_local.y*B + H_local.z*N;
    if(dot(bH, bH) < 1e-9) { pdf = 1e-6; return vec3(0.0); }
    vec3 H = normalize(bH);

    vec3 L = reflect(-V, H);
    if (dot(N, L) <= 0.0) {
        pdf = 1e-6;
        return vec3(0.0);
    }

    float NdotH = max(dot(N, H), 1e-6);
    float VdotH = max(dot(V, H), 1e-6);
    float D = (a*a) / max(1e-5, (PI * pow(NdotH*NdotH * (a*a - 1.0) + 1.0, 2.0)));

    pdf = D * NdotH / (4.0 * VdotH);
    return normalize(L);
}

// As the throughput gets smaller, the ray is more likely to get terminated early.
// Survivors have their value boosted to make up for fewer samples being in the average.
// Retruns wether the path is died or not
bool RussianRoulette(inout vec3 throughput) {
    float p = clamp(max(throughput.r, max(throughput.g, throughput.b)), 0.05, 1.0);
    if (RandomFloat01(seed) > p) return true;

    // Add the energy we 'lose' by randomly terminating paths
    throughput *= 1.0f / p;
    return false;
}

float MISWeight(float pdf_a, float pdf_b) {
    float a2 = pdf_a * pdf_a;
    float b2 = pdf_b * pdf_b;
    return a2 / max(1e-6, (a2 + b2));
}

RenderData worldRender(vec2 uv, Ray ray) {
    Hit hit;
    vec3 radiance = vec3(0.0);
    vec3 throughput = vec3(1.0);

    float prevPdfBSDF = 1.0;
    for(int i = 0; i < pc.lightBounces; i++) {
        if (USE_STATS) {
            if (i == 0) statsPrimaryRays++;
            else statsSecondaryRays++;
        }
        hit = world(ray);
        if(hit.t >= MAX_DIST) { 
            radiance += throughput * skyColor(uv).rgb; 
            break; 
        }

        uint triIdx = (hit.triIdx&(~(1u<<30)));
        bool isLightHit = (hit.triIdx&(1u<<30)) != 0;
        uvec4 triIndices = !isLightHit ? triangleIndices[triIdx] : emissiveIndices[triIdx];

        vec3 v0 = vertexPositions[triIndices.x].xyz;
        vec3 v1 = vertexPositions[triIndices.y].xyz;
        vec3 v2 = vertexPositions[triIndices.z].xyz;

        vec3 hitPoint = ray.origin + ray.dir * hit.t;
        vec3 N = normalize(cross(v1-v0, v2-v0));
        Material mat = mats[triIndices.w];

        // Emission if hit light
        if(mat.emissivePower > 0.0) {
            vec3 Le = mat.emissiveColor * mat.emissivePower;
            if(i > 0) {
                float pdfLight = computeLightPdf(hitPoint, ray.origin, triIdx);
                float w = MISWeight(prevPdfBSDF, pdfLight);
                radiance += throughput * Le * w;
            }
            else radiance += throughput * Le;
            break;
        }

        ray.origin = hitPoint + N * NORMAL_OFFSET;
        vec3 V = normalize(-ray.dir);

        float glossyWeight = clamp(mat.specular, 0.0, 1.0);
        float diffuseWeight = 1.0 - glossyWeight;

        LightSample ls = sampleNEE(hitPoint, N);
        bool didNEE = ls.pdf > 0.0;

        if(didNEE) {
            float cosS = max(dot(N, ls.wi), 0.0);
            float pdfBSDF = glossyWeight * ggxPdf(N, V, ls.wi, mat.roughness) + diffuseWeight * cosS * INV_PI;
            pdfBSDF = max(pdfBSDF, 1e-6);

            float w = MISWeight(ls.pdf, pdfBSDF);

            vec3 f = glossyWeight * ggxBRDF(N, V, ls.wi, mat.roughness, mat.albedo.rgb) + diffuseWeight * mat.albedo.rgb * INV_PI;
            radiance += throughput * f * ls.Le * cosS * w / ls.pdf;
        }


        vec3 wi;
        float pdfBSDF;
        vec3 f;

        float rnd = RandomFloat01(seed);
        if (rnd < glossyWeight) {
            // ---- GGX ----
            float pdfGGX;
            wi = sampleGGX(N, V, mat.roughness, pdfGGX);

            if (pdfGGX <= 1e-6 || dot(N, wi) <= 0.0) break;

            float cosTheta = max(dot(N, wi), 0.0);
            f = ggxBRDF(N, V, wi, mat.roughness, mat.albedo.rgb);

            pdfBSDF = glossyWeight * pdfGGX + diffuseWeight * cosTheta * INV_PI;
        } else {
            // ---- DIFFUSE ----
            wi = diffuseSample(N);
            float cosTheta = max(dot(N, wi), 0.0);

            f = mat.albedo.rgb * INV_PI;

            pdfBSDF = glossyWeight * ggxPdf(N, V, wi, mat.roughness) + diffuseWeight * cosTheta * INV_PI;
        }

        if (pdfBSDF <= 1e-6) break;
        pdfBSDF = max(pdfBSDF, 1e-6);
        prevPdfBSDF = pdfBSDF;

        float cosTheta = max(dot(N, wi), 0.0);
        throughput *= f * cosTheta / pdfBSDF;

        ray.dir = wi;

        if(i > 4 && RussianRoulette(throughput)) break; // i > 4 to avoid branching
    }

    if (any(isnan(radiance)) || any(isinf(radiance))) radiance = vec3(0.0);
    return RenderData(vec4(radiance, 1.0));
}


void main()
{
    //uint lid = gl_LocalInvocationID.x;
    //if (lid >= pc.ct.tileSize.x/2) return;
    iResolution = pathtracerState.iResolution;
    iTime = pathtracerState.iTime;
    iFrame = pathtracerState.iFrame;
    cameraPos = pathtracerState.camera.cameraPos.xyz;
    cameraRot = pathtracerState.camera.cameraRot.xyz;
    uvec2 localID = gl_GlobalInvocationID.xy;
    if (localID.x >= pc.ct.tileSize.x || localID.y >= pc.ct.tileSize.y)
        return;

    uvec2 pixel = pc.ct.tileOffset + localID;

    if (pixel.x >= iResolution.x || pixel.y >= iResolution.y)
        return;

    iSampleFrame = uint(iFrame) / PIXEL_SAMPLE_STRIDE;
    bool doPixel = (((pixel.x ^ pixel.y ^ uint(iFrame)) & 1u) == 0u);
    uint pixelParity = (pixel.x ^ pixel.y) & 1u;
    uint frameParity = uint(iFrame) & 1u;
    uint pixelSampleCount = iSampleFrame + ((pixelParity == 0u || frameParity == 1u) ? 1u : 0u);
    if (!doPixel) {
        vec4 lastSum = imageLoad(accImage, ivec2(pixel));
        vec3 color = (pixelSampleCount == 0u) ? vec3(0.0) : (lastSum.rgb / float(pixelSampleCount));
        imageStore(outImage, ivec2(pixel), vec4(color, 1.0));
        return;
    }

    // Normalized pixel coordinates (from 0 to 1)
    vec2 uv = vec2(pixel)/iResolution.xy * 2.0 - 1.0;
    float aspect = iResolution.x / iResolution.y;
    uv.x *= aspect;
    lightPos = vec3(sin(3.14/2.0), 1.0, cos(3.14/2.0)) * 4.0;
    genSeed();
    
    // calculate subpixel camera jitter for anti aliasing
    vec2 jitter = vec2(RandomFloat01(seed), RandomFloat01(seed)) - 0.5f;
    vec2 jitteredUV = (vec2(pixel) + jitter) / iResolution.xy;
    jitteredUV = jitteredUV * 2.0 - 1.0;
    jitteredUV.y = -jitteredUV.y;
    jitteredUV.x *= aspect;
    jitteredUV.x = -jitteredUV.x;
    
    vec3 ro = cameraPos.xyz;
    vec3 rd = normalize(vec3(jitteredUV, 1.0));
    rd.yz *= rotation(cameraRot.x);
    rd.xz *= rotation(cameraRot.y);
    rd.xy *= rotation(cameraRot.z);

    // Orbit
    //ro.xz *= rotation(iTime);
    //rd.xz *= rotation(iTime);

    Ray ray = Ray(ro, rd);
    
    vec4 finalRender = worldRender(uv, ray).color;
    vec3 finalColor = finalRender.rgb;
    
    vec4 lastSum = imageLoad(accImage, ivec2(pixel));
    if(iSampleFrame == 0u) lastSum = vec4(0.0);
    vec4 newSum = lastSum + vec4(finalRender.rgb, 0.0);
    imageStore(accImage, ivec2(pixel), newSum);

    if(USE_STATS) {
        atomicAdd(statistics.rays, uint64_t(statsRays));
        atomicAdd(statistics.traversals, uint64_t(statsTraversals));
        atomicAdd(statistics.isecs, uint64_t(statsIsecs));
        atomicAdd(statistics.primaryRays, uint64_t(statsPrimaryRays));
        atomicAdd(statistics.secondaryRays, uint64_t(statsSecondaryRays));
        atomicAdd(statistics.shadowRays, uint64_t(statsShadowRays));
    }

    finalColor = newSum.rgb / float(pixelSampleCount);
    imageStore(outImage, ivec2(pixel), vec4(finalColor, 1.0));
}
