vec3 triIntersect( in vec3 ro, in vec3 rd, in vec3 v0, in vec3 v1, in vec3 v2 )
{
    vec3 v1v0 = v1 - v0;
    vec3 v2v0 = v2 - v0;
    vec3 rov0 = ro - v0;
    vec3  n = cross( v1v0, v2v0 );
    vec3  q = cross( rov0, rd );
    float d = 1.0/dot( rd, n );
    float u = d*dot( -q, v2v0 );
    float v = d*dot(  q, v1v0 );
    float t = d*dot( -n, rov0 );
    if( u<0.0 || v<0.0 || (u+v)>1.0 ) t = -1.0;
    return vec3( t, u, v );
}

bool miss(float hit) { return hit <= MIN_TRACE_DIST || hit > MAX_DIST; }

#define SPHERE_TYPE 0
#define BOX_TYPE 1

struct IsecInfo {
    float tmin;
    float tmax;
};

IsecInfo RayAABBIsec(Ray ray, vec3 bbMin, vec3 bbMax, vec3 invDir) {
    IsecInfo info;
    vec3 t0s = (bbMin - ray.origin) * invDir;
    vec3 t1s = (bbMax - ray.origin) * invDir;
    vec3 tsmaller = min(t0s, t1s);
    vec3 tbigger  = max(t0s, t1s);
    float tmin = max(max(tsmaller.x, tsmaller.y), max(tsmaller.z, 0.0));
    float tmax = min(min(tbigger.x, tbigger.y), tbigger.z);
    info.tmin = tmin;
    info.tmax = tmax;
    return info;
}

void TraversalBVH(Ray ray, inout Hit hit) {
    //if(USE_STATS) atomicAdd(statistics.rays, 1ul);
    if (USE_STATS) statsRays++;
    vec3 invDir = 1.0 / ray.dir;
    int stack[MAX_TRAVERSAL_DEPTH];
    int stkptr = 0;
    stack[stkptr++] = 0;

    while (stkptr > 0 && stkptr + 2 < MAX_TRAVERSAL_DEPTH) {
        //if(USE_STATS) atomicAdd(statistics.traversals, 1ul);
        if (USE_STATS) statsTraversals++;
        int nodeIdx = stack[--stkptr];
        BVHNode n = bvhNodes[nodeIdx];

        bool isLeaf = (n.left == -1);

        if (isLeaf) {
            for (uint i = 0; i < n.triCount; ++i) {
                //if(USE_STATS) atomicAdd(statistics.isecs, 1ul);
                if (USE_STATS) statsIsecs++;
                uvec4 triIndices = triangleIndices[n.triIdx + i];

                vec3 v0 = vertexPositions[triIndices.x].xyz;
                vec3 v1 = vertexPositions[triIndices.y].xyz;
                vec3 v2 = vertexPositions[triIndices.z].xyz;

                vec3 isec = triIntersect(ray.origin, ray.dir, v0, v1, v2);
                if (miss(isec.x)) continue;

                if (isec.x > hit.t) continue;
                hit.t = isec.x;
                hit.u = isec.y;
                hit.v = isec.z;
                hit.triIdx = n.triIdx + i;
            }
        } else {
            bool hitL = false, hitR = false;
            IsecInfo lIsec, rIsec;

            if (n.left >= 0) {
                lIsec = RayAABBIsec(ray, n.lBboxMin, n.lBboxMax, invDir);
                hitL = !(lIsec.tmax < lIsec.tmin || lIsec.tmin > hit.t);
            }

            if (n.right >= 0) {
                rIsec = RayAABBIsec(ray, n.rBboxMin, n.rBboxMax, invDir);
                hitR = !(rIsec.tmax < rIsec.tmin || rIsec.tmin > hit.t);
            }

            if (hitL && hitR) {
                // push far first, near last
                if (lIsec.tmin < rIsec.tmin) {
                    stack[stkptr++] = n.right;
                    stack[stkptr++] = n.left;
                } else {
                    stack[stkptr++] = n.left;
                    stack[stkptr++] = n.right;
                }
            } 
            else if (hitL) stack[stkptr++] = n.left;
            else if (hitR) stack[stkptr++] = n.right;
        }
    }
}

void TraversalBVH4(Ray ray, inout Hit hit) {
    if (USE_STATS) statsRays++;
    vec3 invDir = 1.0 / ray.dir;
    int stack[MAX_TRAVERSAL_DEPTH];
    int stkptr = 0;
    stack[stkptr++] = 0;

    while (stkptr > 0) {
        if (USE_STATS) statsTraversals++;
        int nodeIdx = stack[--stkptr];
        BVH4Node n = bvh4Nodes[nodeIdx];

        bool isLeaf = (n.child[0] == -1);
        if (isLeaf) {
            for (uint i = 0; i < n.triCount; ++i) {
                if (USE_STATS) statsIsecs++;
                uvec4 triIndices = triangleIndices[n.triIdx + i];

                vec3 v0 = vertexPositions[triIndices.x].xyz;
                vec3 v1 = vertexPositions[triIndices.y].xyz;
                vec3 v2 = vertexPositions[triIndices.z].xyz;

                vec3 isec = triIntersect(ray.origin, ray.dir, v0, v1, v2);
                if (miss(isec.x)) continue;

                if (isec.x > hit.t) continue;
                hit.t = isec.x;
                hit.u = isec.y;
                hit.v = isec.z;
                hit.triIdx = n.triIdx + i;
            }
        }
        else {
            int childIds[4];
            float childTmin[4];
            int hitCount = 0;

            for (int i = 0; i < 4; i++) {
                int childIdx = n.child[i];
                if (childIdx < 0)
                    continue;

                IsecInfo isec = RayAABBIsec(ray, n.bboxMin[i], n.bboxMax[i], invDir);
                bool childHit = !(isec.tmax < isec.tmin || isec.tmin > hit.t);
                if (!childHit)
                    continue;

                int insertPos = hitCount;
                while (insertPos > 0 && childTmin[insertPos - 1] > isec.tmin) {
                    childTmin[insertPos] = childTmin[insertPos - 1];
                    childIds[insertPos] = childIds[insertPos - 1];
                    insertPos--;
                }
                childTmin[insertPos] = isec.tmin;
                childIds[insertPos] = childIdx;
                hitCount++;
            }

            const int freeSlots = MAX_TRAVERSAL_DEPTH - stkptr;
            const int keepCount = min(hitCount, freeSlots);

            // Keep nearest children when stack is near capacity.
            for (int i = keepCount - 1; i >= 0; i--)
                stack[stkptr++] = childIds[i];
        }
    }
}

struct SpaceContext {
    uint node;
    float tmin;
    float tmax;
};

void TraversalKdTree(Ray ray, inout Hit hit) {
    //if(USE_STATS) atomicAdd(statistics.rays, 1ul);
    if (USE_STATS) statsRays++;
    vec3 invDir = 1.0 / ray.dir;
    SpaceContext stack[MAX_TRAVERSAL_DEPTH];
    int stkptr = 0;
    stack[stkptr++] = SpaceContext(0, -INF, INF);

    while (stkptr > 0 && stkptr + 2 < MAX_TRAVERSAL_DEPTH) {
        //if(USE_STATS) atomicAdd(statistics.traversals, 1ul);
        if (USE_STATS) statsTraversals++;
        SpaceContext sc = stack[--stkptr];
        KdNode n = kdNodes[sc.node];

        if (sc.tmin >= hit.t || sc.tmin > sc.tmax) continue;

        bool isLeaf = (n.left == -1);
        if (isLeaf) {
            for (uint i = 0; i < n.triCount; ++i) {
                //if(USE_STATS) atomicAdd(statistics.isecs, 1ul);
                if (USE_STATS) statsIsecs++;
                uvec4 triIndices = triangleIndices[kdtreeIndices[n.triIdx + i]];

                vec3 v0 = vertexPositions[triIndices.x].xyz;
                vec3 v1 = vertexPositions[triIndices.y].xyz;
                vec3 v2 = vertexPositions[triIndices.z].xyz;

                vec3 isec = triIntersect(ray.origin, ray.dir, v0, v1, v2);
                if (miss(isec.x)) continue;

                if (isec.x > hit.t) continue;
                hit.t = isec.x;
                hit.u = isec.y;
                hit.v = isec.z;
                hit.triIdx = kdtreeIndices[n.triIdx + i];
            }
        } else {
            float splitPos = uintBitsToFloat(n.triIdx);
            uint axis = n.triCount;
            float tsplit = (splitPos - ray.origin[axis]) * invDir[axis];
            bool below = ray.origin[axis] < splitPos || (ray.origin[axis] == splitPos && ray.dir[axis] <= 0.0);
            uint near = below ? n.left  : n.right;
            uint far  = below ? n.right : n.left;
            if (tsplit >= sc.tmax || tsplit <= 0) stack[stkptr++] = SpaceContext(near, sc.tmin, sc.tmax);
            else if (tsplit <= sc.tmin) stack[stkptr++] = SpaceContext(far, sc.tmin, sc.tmax);
            else {
                stack[stkptr++] = SpaceContext(far,  tsplit, sc.tmax);
                stack[stkptr++] = SpaceContext(near, sc.tmin, tsplit);
            }
            
        }

    }
}

/*
    ray.origin = (-0.2, 0.1, -0.6)
    ray.dir = (-, +, +)

    Node 0 (axis = 2) (-INF, INF) => tsplit0 = (0.77 - -0.6) / + = +, below = (-0.6 < 0.77) = true => near(left, -INF, tsplit0), far(right, tsplit0, INF)
    Node 1 (axis = 0) (-INF, tsplit0) => tsplit1 = (0.0 - -0.2) / - = -, below = (-0.2 < 0.0) = true => near(left, -INF, tsplit0)
    Node 2 (axis = 1) (-INF, tsplit0) => tsplit2 = (0.0 - 0.1) / + = -, below = (0.1 < 0.0) = false => near(right, -INF, tsplit2) far(left, tsplit2, tsplit0)

    near(left, -INF, tsplit0)
    near(left, -INF, tsplit0)
    far(left, tsplit2, tsplit0)
*/

void TraversalBruteForce(Ray ray, inout Hit hit) {
    for (uint tIdx = 0; tIdx < triangleIndices.length(); ++tIdx) {
        uvec4 triIndices = triangleIndices[tIdx];
        vec3 v0 = vertexPositions[triIndices.x].xyz;
        vec3 v1 = vertexPositions[triIndices.y].xyz;
        vec3 v2 = vertexPositions[triIndices.z].xyz;
        vec3 isec = triIntersect(ray.origin, ray.dir, v0, v1, v2);
        
        if (miss(isec.x)) continue;
        if (isec.x >= hit.t) continue;
        hit.t = isec.x;
        hit.u = isec.y;
        hit.v = isec.z;
        hit.triIdx = tIdx;
    }
}

void EmissiveTraversalBF(Ray ray, inout Hit hit) {
    for (uint tIdx = 0; tIdx < emissiveIndices.length(); ++tIdx) {
        uvec4 triIndices = emissiveIndices[tIdx];
        vec3 v0 = vertexPositions[triIndices.x].xyz;
        vec3 v1 = vertexPositions[triIndices.y].xyz;
        vec3 v2 = vertexPositions[triIndices.z].xyz;
        vec3 isec = triIntersect(ray.origin, ray.dir, v0, v1, v2);
        if (miss(isec.x)) continue;
        if (isec.x < hit.t) {
            hit.t = isec.x;
            hit.u = isec.y;
            hit.v = isec.z;
            hit.triIdx = tIdx | (1<<30);
        }
    }
}

Hit world(Ray ray) {
    Hit hit;
    hit.t = MAX_DIST;
    //hit.d2 = MAX_DIST;

    switch (ACCELERATION_STRUCTURE_TYPE) {
    case AS_BVH:
        TraversalBVH(ray, hit);
        break;
    case AS_BVH4:
        TraversalBVH4(ray, hit);
        break;
    case AS_KD_TREE:
    default:
        TraversalKdTree(ray, hit);
        break;
    }

    EmissiveTraversalBF(ray, hit);

    return hit;
}

